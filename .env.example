# Backend chính khi chạy trên máy thuê:
# - local_webui: AUTOMATIC1111 / Forge / SD.Next API
# - comfyui: ComfyUI workflow API, phù hợp Flux
# - openrouter: dùng OpenRouter Image API
GEN_BACKEND=local_webui

# File prompt và thư mục xuất ảnh
PROMPTS_FILE=prompts.json
OUTPUT_DIR=video_assets
IMAGE_WIDTH=1024
IMAGE_HEIGHT=576
OUTPUT_FORMAT=png
SKIP_EXISTING=true
RETRIES=2
RETRY_DELAY=3

# local_webui: bật WebUI với --api rồi giữ URL này
WEBUI_URL=http://127.0.0.1:7860
WEBUI_STEPS=25
WEBUI_CFG_SCALE=6
WEBUI_SAMPLER=DPM++ 2M Karras
WEBUI_SEED=-1
WEBUI_MODEL_CHECKPOINT=
WEBUI_NEGATIVE_PROMPT=blurry, low quality, distorted, deformed, bad anatomy, watermark, text
WEBUI_TIMEOUT=300

# comfyui: export workflow dạng API JSON và đặt __PROMPT__ vào node prompt
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW=workflow_api.json
COMFYUI_TIMEOUT=600
# Nếu không dùng placeholder, điền node ID cụ thể:
COMFYUI_PROMPT_NODE_ID=
COMFYUI_PROMPT_FIELD=text
COMFYUI_NEGATIVE_NODE_ID=
COMFYUI_NEGATIVE_FIELD=text
COMFYUI_WIDTH_NODE_ID=
COMFYUI_WIDTH_FIELD=width
COMFYUI_HEIGHT_NODE_ID=
COMFYUI_HEIGHT_FIELD=height
COMFYUI_SEED_NODE_ID=
COMFYUI_SEED_FIELD=seed

# openrouter fallback
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TIMEOUT=180
